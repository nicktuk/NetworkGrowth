generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  plan          Plan      @default(TRIAL)
  trialEndsAt   DateTime  @default(dbgenerated("NOW() + INTERVAL '14 days'"))
  mpSubscriptionId String? // MercadoPago — encriptado
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  businessProfile BusinessProfile?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text  // encriptado AES-256 antes de guardar
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── NEGOCIO ─────────────────────────────────────────────────────────────────

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  queVende     String   // Respuesta libre: "mates artesanales y accesorios"
  clienteIdeal String   // Respuesta libre: "personas que toman mate, 25-45 años"
  pais         String   @default("AR")
  igHandle     String?  // Handle de IG del usuario (si conectó OAuth)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  inspirationAccounts InspirationAccount[]
  contentPlans        ContentPlan[]
  igAccount           IgAccount?

  @@map("business_profiles")
}

// ─── CUENTAS DE INSPIRACIÓN ──────────────────────────────────────────────────

model InspirationAccount {
  id                String   @id @default(cuid())
  businessProfileId String
  igHandle          String   // Ej: "yerbaselena"
  displayName       String?
  followerCount     Int?
  lastPostsJson     Json?    // Últimos 20 posts con métricas — actualizado semanalmente
  lastFetchedAt     DateTime?
  createdAt         DateTime @default(now())

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, igHandle])
  @@map("inspiration_accounts")
}

// ─── CUENTA IG PROPIA (OAuth) ─────────────────────────────────────────────────

model IgAccount {
  id                String   @id @default(cuid())
  businessProfileId String   @unique
  igUserIdEnc       String   // ID de IG — encriptado AES-256
  accessTokenEnc    String   @db.Text // Token OAuth — encriptado AES-256. Nunca sale de la DB.
  tokenExpiresAt    DateTime?
  username          String   // Handle público — puede mostrarse
  followerCount     Int?
  lastHistoryJson   Json?    // Últimas 4 semanas de posts con métricas
  lastFetchedAt     DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@map("ig_accounts")
}

// ─── PLANES DE CONTENIDO ─────────────────────────────────────────────────────

model ContentPlan {
  id                String   @id @default(cuid())
  businessProfileId String
  weekOf            DateTime // Lunes de la semana a la que corresponde el plan
  planJson          Json     // Array de piezas: tema, formato, hook, por qué, cuándo
  diagnosticoJson   Json?    // Diagnóstico semana anterior — solo Pro, null si Starter
  generatedAt       DateTime @default(now())

  businessProfile BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@unique([businessProfileId, weekOf])
  @@map("content_plans")
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Plan {
  TRIAL
  STARTER
  PRO
  AGENCY
  CANCELLED
}
